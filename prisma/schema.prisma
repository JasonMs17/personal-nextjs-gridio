// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================== WORKSPACE SYSTEM =====================
// Sistem untuk tracking categories dan entries per workspace
// ============================================================

model Workspace {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  categories  Category[]

  @@map("workspaces")
}

model Category {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  icon        String    @default("📝")
  color       String    @default("#808080")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  entries     Entry[]

  @@map("categories")
}

model Entry {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  entryDate  DateTime @map("entry_date") @db.Date
  title      String
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([categoryId, entryDate])
  @@map("entries")
}

// ===================== BUDGETING SYSTEM =====================
// Sistem untuk tracking budget, accounts, dan transactions
// ============================================================

model Account {
  id              String                @id @default(uuid())
  name            String
  balance         Decimal               @default(0)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  transactions    BudgetTransaction[]   @relation("fromAccount")
  incomingTransfers BudgetTransaction[] @relation("toAccount")

  @@map("accounts")
}

model BudgetCategory {
  id           String                @id @default(uuid())
  name         String
  type         String // 'income' atau 'expense'
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  transactions BudgetTransaction[]

  @@map("budget_categories")
}

model BudgetTransaction {
  id             String          @id @default(uuid())
  accountId      String          @map("account_id")
  account        Account         @relation("fromAccount", fields: [accountId], references: [id], onDelete: Cascade)
  toAccountId    String?         @map("to_account_id")
  toAccount      Account?        @relation("toAccount", fields: [toAccountId], references: [id], onDelete: Cascade)
  categoryId     String?         @map("category_id")
  category       BudgetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  type           String // 'income', 'expense', atau 'transfer'
  amount         Decimal         @db.Decimal(12, 2)
  description    String?
  transactionDate DateTime       @map("transaction_date") @db.Date
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("budget_transactions")
}
